//  SEND ORDER
// ═══════════════════════════════════════
async function sendOrder() {
  const name   = document.getElementById('uName').value.trim();
  const phone  = document.getElementById('uPhone').value.trim();
  const region = document.getElementById('uRegion').value.trim();

  if (!name)                              return showErr('❌ يرجى كتابة الاسم');
  if (phone.length!==11 || isNaN(+phone)) return showErr('❌ رقم الهاتف يجب أن يكون 11 رقمًا');
  if (!region)                             return showErr('❌ يرجى إدخال اسم المنطقة');
  if (!locUrl)                             return showErr('❌ يرجى تحديد موقعك على الخريطة');
  if (!files.length)                       return showErr('❌ يرجى رفع ملف واحد على الأقل');
  hideErr();

  const btn = document.getElementById('sendbtn');
  btn.disabled = true; btn.innerText = 'جاري الإرسال... 🚀';
  document.getElementById('pcon').style.display = 'block';
  const stxt = document.getElementById('statustxt'); stxt.style.display = 'block';

  try {
    const oid = 'SH-' + Math.floor(1000+Math.random()*9000);
    const {pp,df,td,pd,tot,pe,isFO} = window._ord || {};
    const useP = document.getElementById('ptstog')?.checked && pendingR;
    const pu   = useP ? pendingR.pts : 0;

    stxt.innerText = 'جاري تجهيز وضغط الملفات...';
    document.getElementById('pbar').style.width = '20%';
    const zip = new JSZip();
    const folder = zip.folder('order-' + oid);
    const meta = [];
    for (const f of files) {
      const buf = await f.file.arrayBuffer();
      for (let c=1; c<=f.c; c++) folder.file(f.c>1?`(${c}) ${f.name}`:f.name, buf);
      meta.push({name:f.name, pages:f.p, copies:f.c, type:f.type});
    }
    const zipBlob = await zip.generateAsync({type:'blob',compression:'DEFLATE',compressionOptions:{level:6}}, m => {
      document.getElementById('pbar').style.width = (20+m.percent*.4)+'%';
    });

    stxt.innerText = 'جاري رفع الملفات إلى السيرفر...';
    const zpath = `orders/${oid}/files_${oid}.zip`;
    const {error: uploadError} = await sb.storage.from('order-files').upload(zpath, zipBlob, {cacheControl:'3600',upsert:true});
    if (uploadError) throw new Error('فشل الرفع: تأكد من إعدادات الـ Storage');

    const {data: urlData} = sb.storage.from('order-files').getPublicUrl(zpath);
    const zipUrl = urlData?.publicUrl || '';
    document.getElementById('pbar').style.width = '80%';

    stxt.innerText = 'جاري تسجيل الطلب...';
    const order = {
      id:oid, user_id:userId, telegram_id:userId,
      name, phone, region, loc_url:locUrl,
      files:meta, zip_url:zipUrl,
      color, side,
      print_price:pp||0, delivery_fee:df||0,
      tier_discount:td||0, pts_discount:pd||0,
      pts_used:pu, total:tot||0,
      loyalty_points_earned:pe||0,
      is_first_order:!!isFO,
      status:'received',
      status_history:[{status:'received',time:new Date().toISOString()}]
    };
    const {error: dbError} = await sb.from('orders').insert(order);
    if (dbError) throw dbError;

    const np = Math.max(0, (uDoc.loyalty_points||0)+(pe||0)-pu);
    await sb.from('users').update({
      loyalty_points:np, total_orders:(uDoc.total_orders||0)+1,
      total_spent:(uDoc.total_spent||0)+(tot||0),
      first_order_done:true, name, phone
    }).eq('id', userId);
    uDoc.loyalty_points=np; uDoc.first_order_done=true;

    document.getElementById('pbar').style.width = '100%';

    const flist = meta.map(f=>`📄 ${f.name} (${f.pages}ص × ${f.copies}ن)`).join('\n');
    const adminMsg =
      `🆕 طلب جديد #${oid}\n👤 ${name}\n📞 ${phone}\n🏠 ${region}\n` +
      `🎨 ${color==='c'?'ملون':'أسود'} - ${side==='1'?'وجه واحد':'وجهين'}\n` +
      `💰 ${(tot||0).toLocaleString()} د.ع\n📍 ${locUrl}\n\n📋 الملفات:\n${flist}\n\n📦 رابط التحميل:\n${zipUrl}`;
    await tgMsg(ADMIN, adminMsg);
    if (tgU?.id) await tgMsg(String(tgU.id), `✅ تم استلام طلبك #${oid} بنجاح!\n💎 ستكسب ${pe||0} نقطة عند التسليم.\n\nسنُخطرك بكل تحديث 🔔`);

    pendingR=null;
    refreshPtsUI();
    showSuccessUI(oid, pe||0, np);

  } catch(e) {
    console.error(e);
    showErr('❌ حدث خطأ أثناء الإرسال: ' + e.message);
    btn.disabled=false; btn.innerText='🚀 تأكيد وإرسال الطلب';
    stxt.style.display='none';
  }
}

