document.getElementById('fileinp').onchange = async e => {
  const ok=['.pdf','.docx','.doc','.xlsx','.xls','.pptx','.ppt','.jpg','.jpeg','.png','.webp'];
  for (const f of e.target.files) {
    const nm = f.name.toLowerCase(), ext = nm.substring(nm.lastIndexOf('.'));
    if (!ok.includes(ext) && !f.type.startsWith('image/')) continue;
    const obj = {file:f, name:f.name, p:1, c:1, isImg:f.type.startsWith('image/'), type:'ملف'};
    try {
      const buf = await f.arrayBuffer();
      if (nm.endsWith('.pdf')) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
        obj.p = (await pdfjsLib.getDocument({data:buf}).promise).numPages;
        obj.type = 'PDF'; obj.isImg = false;
      } else if (nm.endsWith('.docx') || nm.endsWith('.doc')) {
        try {
          const z = await JSZip.loadAsync(buf), xf = z.file('docProps/app.xml');
          if (xf) { const m = (await xf.async('string')).match(/<Pages>(\d+)<\/Pages>/); if(m) obj.p = +m[1]; }
        } catch {
          const r = await mammoth.extractRawText({arrayBuffer:buf});
          obj.p = Math.max(1, Math.ceil(r.value.trim().split(/\s+/).length / 300));
        }
        obj.type = 'Word'; obj.isImg = false;
      } else if (nm.endsWith('.pptx') || nm.endsWith('.ppt')) {
        const z = await JSZip.loadAsync(buf), xf = z.file('docProps/app.xml');
        if (xf) { const m = (await xf.async('string')).match(/<Slides>(\d+)<\/Slides>/); if(m) obj.p = +m[1]; }
        obj.type = 'PowerPoint'; obj.isImg = false;
      } else if (nm.endsWith('.xlsx') || nm.endsWith('.xls')) {
        const wb = XLSX.read(buf,{type:'array'}); let tot = 0;
        wb.SheetNames.forEach(s => { const sh=wb.Sheets[s], r=XLSX.utils.decode_range(sh['!ref']||'A1:A1'); tot+=Math.ceil((r.e.r-r.s.r+1)/45)*Math.ceil((r.e.c-r.s.c+1)/8); });
        obj.p = Math.max(1,tot); obj.type = 'Excel'; obj.isImg = false;
      } else if (obj.isImg) obj.type = 'صورة';
    } catch { obj.p = 1; }
    files.push(obj);
  }
  calcUI(); e.target.value = '';
};

