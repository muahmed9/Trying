<!DOCTYPE html>
<html lang="ar" dir="rtl" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>خدمات الشاطر الطلابية</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.4.21/mammoth.browser.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap');

/* ══════════════════════════════════════
   THEME VARIABLES — Light & Dark
══════════════════════════════════════ */
:root {
  --navy:        #0d3b66;
  --teal:        #5ab3c4;
  --orange:      #e86b24;
  --light-teal:  #eef9fa;
  --bg:          #f4f7f9;
  --card:        #ffffff;
  --text-main:   #1e293b;
  --text-muted:  #64748b;
  --green:       #10b981;
  --red:         #ef4444;
  --gold:        #f59e0b;
  --border:      rgba(0,0,0,0.05);
  --inv-bg:      var(--navy);
  --inv-row-bg:  rgba(0,0,0,0.15);
  --input-bg:    #f8fafc;
  --blue:        var(--navy);
}

[data-theme="dark"] {
  --bg:         #0f172a;
  --card:       #1e293b;
  --text-main:  #e2e8f0;
  --text-muted: #94a3b8;
  --light-teal: rgba(90,179,196,0.08);
  --border:     rgba(255,255,255,0.07);
  --inv-bg:     #0d2744;
  --inv-row-bg: rgba(255,255,255,0.07);
  --input-bg:   #0f172a;
}

/* ══════════════════════════════════════
   GLOBAL
══════════════════════════════════════ */
* { box-sizing: border-box; font-family: 'Tajawal', sans-serif; -webkit-tap-highlight-color: transparent; }
body { background: var(--bg); direction: rtl; margin: 0; padding: 0 0 85px; color: var(--text-main); transition: background 0.3s, color 0.3s; }

@keyframes fadeInUp  { from { opacity:0; transform:translateY(15px); } to { opacity:1; transform:translateY(0); } }
@keyframes pulseGlow { 0%{box-shadow:0 0 0 0 rgba(232,107,36,.4);}70%{box-shadow:0 0 0 10px rgba(232,107,36,0);}100%{box-shadow:0 0 0 0 rgba(232,107,36,0);} }
@keyframes spin       { to { transform: rotate(360deg); } }
@keyframes pop        { 0%{transform:scale(0.8);opacity:0;}80%{transform:scale(1.05);}100%{transform:scale(1);opacity:1;} }

/* ══════════════════════════════════════
   LOGO
══════════════════════════════════════ */
.app-logo {
  width:90px; height:90px; border-radius:50%;
  border:3px solid var(--teal); padding:4px;
  background:#fff; box-shadow:0 6px 20px rgba(90,179,196,.2);
  margin:0 auto 12px; display:block; object-fit:contain;
}

/* ══════════════════════════════════════
   BOTTOM NAV
══════════════════════════════════════ */
.bnav {
  position:fixed; bottom:0; left:0; right:0;
  background:rgba(255,255,255,.95);
  backdrop-filter:blur(10px);
  border-top:1px solid var(--border);
  display:flex; z-index:200;
  box-shadow:0 -5px 25px rgba(13,59,102,.05);
  padding:5px 10px 15px;
  transition: background 0.3s;
}
[data-theme="dark"] .bnav { background:rgba(30,41,59,.95); }

.nbtn { flex:1; padding:10px 5px; border:none; background:none; cursor:pointer; font-size:.8rem; font-weight:700; color:var(--text-muted); display:flex; flex-direction:column; align-items:center; gap:4px; transition:all .3s; }
.nbtn .ni { font-size:1.5rem; transition:transform .3s cubic-bezier(.175,.885,.32,1.275); }
.nbtn.active { color:var(--teal); }
.nbtn.active .ni { transform:translateY(-4px) scale(1.1); color:var(--navy); }
[data-theme="dark"] .nbtn.active .ni { color:var(--teal); }

/* ── Dark mode toggle in nav ── */
#dm-toggle { flex:0 0 auto; width:44px; }
#dm-toggle .ni { font-size:1.3rem; }

/* ══════════════════════════════════════
   TABS & CARDS
══════════════════════════════════════ */
.tab { display:none; padding:15px; }
.tab.active { display:block; animation:fadeInUp .4s ease forwards; }
.card {
  background:var(--card); border-radius:20px; padding:22px;
  margin-bottom:15px; box-shadow:0 4px 15px rgba(0,0,0,.03);
  border:1px solid var(--border); transition:background .3s;
}
.hdr { text-align:center; padding:10px 0 15px; }

/* ══════════════════════════════════════
   UPLOAD AREA
══════════════════════════════════════ */
.upload {
  border:2px dashed var(--teal); background:var(--light-teal);
  padding:30px 20px; text-align:center; color:var(--navy);
  cursor:pointer; border-radius:20px; transition:all .2s;
}
[data-theme="dark"] .upload { color:var(--teal); }
.upload:active { transform:scale(.98); }
.upload-icon { font-size:2.5rem; margin-bottom:8px; display:block; }

/* ══════════════════════════════════════
   FILE PREVIEW CARDS (تأكيد بصري)
══════════════════════════════════════ */
.file-card {
  display:flex; align-items:center; gap:12px;
  background:var(--input-bg); border:1.5px solid var(--border);
  border-radius:14px; padding:12px 14px; margin-bottom:10px;
  animation:pop .25s ease;
}
.file-icon-box {
  width:46px; height:46px; border-radius:12px;
  display:flex; align-items:center; justify-content:center;
  font-size:1.6rem; flex-shrink:0;
}
.fi-pdf   { background:#fee2e2; }
.fi-word  { background:#dbeafe; }
.fi-xl    { background:#dcfce7; }
.fi-ppt   { background:#ffedd5; }
.fi-img   { background:#fdf4ff; }
.fi-other { background:#f1f5f9; }

.file-info { flex:1; min-width:0; }
.file-name { font-weight:800; font-size:.9rem; color:var(--navy); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:160px; }
[data-theme="dark"] .file-name { color:var(--teal); }
.file-meta { font-size:.78rem; color:var(--text-muted); margin-top:2px; }
.file-badge { font-size:.7rem; font-weight:700; padding:2px 8px; border-radius:8px; background:var(--light-teal); color:var(--teal); display:inline-block; margin-top:3px; }
.file-controls { display:flex; align-items:center; gap:6px; flex-shrink:0; }
.bcnt { background:var(--light-teal); border:none; width:32px; height:32px; border-radius:10px; cursor:pointer; font-weight:800; font-size:1.1rem; color:var(--navy); transition:background .2s; }
.bcnt:active { background:#c7e8ec; }
.file-qty { padding:0 8px; font-weight:800; font-size:1.1rem; color:var(--orange); min-width:24px; text-align:center; }
.del-btn { background:#fef2f2; border:none; color:var(--red); font-size:.8rem; font-weight:700; padding:6px 10px; border-radius:8px; cursor:pointer; }

/* ══════════════════════════════════════
   BUTTONS
══════════════════════════════════════ */
.bgrp { display:flex; gap:10px; margin-top:10px; }
.obtn { flex:1; padding:14px; border:1.5px solid #e2e8f0; border-radius:14px; cursor:pointer; font-weight:700; font-size:.95rem; transition:all .2s; background:var(--card); color:var(--text-muted); }
[data-theme="dark"] .obtn { border-color:#334155; }
.obtn.on { background:var(--navy)!important; color:#fff!important; border-color:var(--navy); box-shadow:0 4px 12px rgba(13,59,102,.2); }
.obtn:active { transform:scale(.96); }
.bmain { width:100%; padding:16px; border:none; border-radius:16px; font-weight:800; font-size:1.1rem; cursor:pointer; transition:all .3s; }
.bmain:active { transform:scale(.97); }
.bmain:disabled { opacity:.7; cursor:not-allowed; transform:none; }
.btn-action { background:var(--orange); color:#fff; box-shadow:0 6px 15px rgba(232,107,36,.25); }

/* ══════════════════════════════════════
   INPUTS
══════════════════════════════════════ */
input[type=text],input[type=tel] {
  width:100%; padding:16px; border:1.5px solid #e2e8f0; border-radius:14px;
  font-size:1rem; margin-bottom:12px; background:var(--input-bg);
  outline:none; transition:border-color .2s,background .2s,color .2s;
  font-family:'Tajawal',sans-serif; color:var(--text-main);
}
[data-theme="dark"] input[type=text],[data-theme="dark"] input[type=tel] { border-color:#334155; }
input:focus { border-color:var(--teal); background:var(--card); box-shadow:0 0 0 4px rgba(90,179,196,.1); }

/* ══════════════════════════════════════
   TOGGLE
══════════════════════════════════════ */
.togw { position:relative; display:inline-block; width:52px; height:28px; flex-shrink:0; }
.togw input { opacity:0; width:0; height:0; }
.togs { position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background:#cbd5e1; border-radius:28px; transition:.4s; }
.togs:before { content:''; position:absolute; width:22px; height:22px; right:3px; bottom:3px; background:#fff; border-radius:50%; transition:.4s; box-shadow:0 2px 4px rgba(0,0,0,.1); }
input:checked+.togs { background:var(--teal); }
input:checked+.togs:before { transform:translateX(-24px); }

/* ══════════════════════════════════════
   INVOICE
══════════════════════════════════════ */
.inv { background:var(--inv-bg); color:#fff; border-radius:18px; padding:22px; margin-top:15px; box-shadow:0 8px 20px rgba(13,59,102,.15); }
.il { display:flex; justify-content:space-between; margin-bottom:10px; font-size:.95rem; opacity:.9; }
.tot { font-size:1.5rem; color:#4eff4e; text-align:center; margin-top:15px; border-top:1px dashed rgba(255,255,255,.2); padding-top:15px; font-weight:800; }

/* ══════════════════════════════════════
   PROGRESS BAR
══════════════════════════════════════ */
.pcon { width:100%; background:#e2e8f0; height:10px; border-radius:5px; margin:15px 0; display:none; overflow:hidden; }
.pbar { width:0; height:100%; background:var(--orange); transition:width .3s ease; border-radius:5px; }

/* ══════════════════════════════════════
   ALERTS
══════════════════════════════════════ */
.inote { color:var(--orange); font-size:.85rem; font-weight:700; margin:12px 0; display:none; border:1px solid rgba(232,107,36,.3); padding:12px; border-radius:12px; background:rgba(232,107,36,.05); text-align:center; }
.errmsg { background:#fef2f2; color:var(--red); padding:12px; border-radius:12px; font-size:.9rem; font-weight:700; margin-bottom:12px; text-align:center; display:none; border:1px solid #fecaca; }
.iosbox { background:#fffbeb; border:1.5px solid #fde68a; border-radius:14px; padding:15px; margin-top:15px; }

/* ══════════════════════════════════════
   ORDER CARDS
══════════════════════════════════════ */
.ocard { background:var(--card); border-radius:16px; padding:18px; margin-bottom:12px; box-shadow:0 3px 10px rgba(0,0,0,.04); border:1px solid var(--border); cursor:pointer; transition:transform .2s; }
.ocard:active { transform:scale(.98); }
.sbadge { display:inline-block; padding:6px 14px; border-radius:20px; font-size:.8rem; font-weight:700; }
.s-r { background:#e0f2fe; color:#1e40af; }
.s-p { background:#fef3c7; color:#b45309; }
.s-d { background:#ffedd5; color:var(--orange); }
.s-v { background:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
.s-c { background:#fee2e2; color:#991b1b; }

/* ── Mini progress dots ── */
.mini-progress { display:flex; align-items:center; gap:4px; margin-top:12px; }
.mp-dot { width:22px; height:6px; border-radius:3px; background:#e2e8f0; flex:1; }
.mp-dot.done { background:var(--green); }
.mp-dot.cur  { background:var(--orange); animation:pulseGlow 2s infinite; }
.mp-label { font-size:.72rem; color:var(--text-muted); margin-top:4px; text-align:center; font-weight:700; }

/* ══════════════════════════════════════
   ORDER DETAIL TIMELINE
══════════════════════════════════════ */
.tlstep { display:flex; align-items:flex-start; gap:15px; margin-bottom:5px; }
.tlc { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; font-weight:bold; transition:all .3s; }
.tld { background:var(--green); color:#fff; box-shadow:0 0 10px rgba(16,185,129,.3); }
.tlcur { background:var(--orange); color:#fff; box-shadow:0 0 15px rgba(232,107,36,.4); animation:pulseGlow 2s infinite; }
.tlpen { background:#f1f5f9; color:#94a3b8; }
[data-theme="dark"] .tlpen { background:#334155; color:#64748b; }
.tlcon { width:2px; height:26px; background:#f1f5f9; margin:2px 0 2px 17px; border-radius:2px; }
.tlcon.done { background:var(--green); }

/* ══════════════════════════════════════
   POINTS
══════════════════════════════════════ */
.ptshero { background:linear-gradient(135deg,var(--navy),var(--teal)); color:#fff; border-radius:24px; padding:30px 25px; margin-bottom:15px; text-align:center; box-shadow:0 8px 20px rgba(13,59,102,.2); }
.ptsnum { font-size:3.5rem; font-weight:800; line-height:1.1; margin:5px 0; }
.tierbadge { display:inline-block; padding:6px 20px; border-radius:20px; font-weight:800; margin:10px 0 8px; box-shadow:0 4px 10px rgba(0,0,0,.1); }
.tgold { background:linear-gradient(135deg,#fcd34d,#f59e0b); color:#78350f; }
.tsilv { background:linear-gradient(135deg,#e2e8f0,#94a3b8); color:#1e293b; }
.tbron { background:linear-gradient(135deg,#fed7aa,#d97706); color:#78350f; }
.ptspw { width:100%; height:10px; background:rgba(255,255,255,.2); border-radius:5px; overflow:hidden; margin:12px 0; }
.ptspf { height:100%; background:#4eff4e; border-radius:5px; transition:width .8s cubic-bezier(.4,0,.2,1); }
.rcard { background:var(--card); border-radius:16px; padding:16px; margin-bottom:12px; display:flex; justify-content:space-between; align-items:center; border:1px solid var(--border); }
.rbtn { background:var(--teal); color:#fff; padding:10px 20px; border-radius:12px; font-size:.9rem; cursor:pointer; font-weight:700; border:none; transition:background .2s; }
.rbtn:disabled { background:#e2e8f0; color:#94a3b8; cursor:not-allowed; }

/* ══════════════════════════════════════
   MODALS & SHEETS
══════════════════════════════════════ */
.shov { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(15,23,42,.6); backdrop-filter:blur(4px); display:none; align-items:flex-end; justify-content:center; z-index:300; }
.shov.open { display:flex; animation:fadeIn .3s; }
.sheet { background:var(--bg); border-radius:28px 28px 0 0; padding:25px 20px; width:100%; max-height:90vh; overflow-y:auto; animation:slideUp .3s cubic-bezier(.175,.885,.32,1.1); box-shadow:0 -10px 30px rgba(0,0,0,.1); }
@keyframes slideUp { from{transform:translateY(100%);} to{transform:translateY(0);} }
.handle { width:50px; height:5px; background:#cbd5e1; border-radius:3px; margin:0 auto 20px; }

/* ══════════════════════════════════════
   ONBOARDING MODAL
══════════════════════════════════════ */
#onboarding {
  position:fixed; top:0; left:0; width:100%; height:100%;
  background:rgba(13,59,102,.92); backdrop-filter:blur(6px);
  display:flex; align-items:center; justify-content:center; z-index:500;
}
.ob-box {
  background:var(--card); padding:32px 25px 25px;
  border-radius:28px; width:92%; max-width:400px;
  box-shadow:0 25px 50px rgba(0,0,0,.25);
  animation:pop .4s ease;
  overflow:hidden; position:relative;
}
.ob-slides { display:flex; transition:transform .35s cubic-bezier(.4,0,.2,1); }
.ob-slide { min-width:100%; text-align:center; padding:0 4px; }
.ob-emoji { font-size:4.5rem; margin-bottom:14px; display:block; }
.ob-title { color:var(--navy); font-size:1.3rem; font-weight:800; margin:0 0 10px; }
[data-theme="dark"] .ob-title { color:var(--teal); }
.ob-desc { color:var(--text-muted); font-size:.95rem; line-height:1.7; font-weight:500; margin:0; }

.ob-dots { display:flex; justify-content:center; gap:7px; margin:20px 0 16px; }
.ob-dot { width:8px; height:8px; border-radius:50%; background:#e2e8f0; transition:all .3s; }
.ob-dot.active { background:var(--orange); width:22px; border-radius:4px; }

.ob-skip {
  position:absolute; top:14px; left:16px;
  background:none; border:none; color:var(--text-muted);
  font-size:.85rem; cursor:pointer; font-weight:700; font-family:'Tajawal',sans-serif;
}
.ob-next {
  width:100%; padding:15px; border:none; border-radius:14px;
  background:var(--orange); color:#fff; font-size:1.05rem;
  font-weight:800; cursor:pointer; font-family:'Tajawal',sans-serif;
  transition:opacity .2s;
}
.ob-next:active { opacity:.85; }

/* ══════════════════════════════════════
   WELCOME MODAL
══════════════════════════════════════ */
#wmodal { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(15,23,42,.85); backdrop-filter:blur(5px); display:none; align-items:center; justify-content:center; z-index:400; }
.mbox { background:var(--card); padding:35px 25px; border-radius:28px; text-align:center; width:90%; max-width:400px; box-shadow:0 20px 40px rgba(0,0,0,.2); animation:pop .4s cubic-bezier(.175,.885,.32,1.2); }

/* ══════════════════════════════════════
   TOAST
══════════════════════════════════════ */
#toast { position:fixed; top:20px; left:50%; transform:translateX(-50%); background:var(--navy); color:#fff; padding:14px 24px; border-radius:16px; font-size:.95rem; font-weight:700; z-index:999; display:none; box-shadow:0 10px 25px rgba(13,59,102,.3); max-width:90%; text-align:center; }

/* ══════════════════════════════════════
   IOS HINT
══════════════════════════════════════ */
.iosbox { background:#fffbeb; border:1.5px solid #fde68a; border-radius:14px; padding:15px; margin-top:15px; }
</style>
</head>
<body>

<!-- ══════════════════════════════════════
     ONBOARDING — 3 شرائح تعريفية
══════════════════════════════════════ -->
<div id="onboarding">
  <div class="ob-box">
    <button class="ob-skip" onclick="finishOnboarding()">تخطي ←</button>

    <div class="ob-slides" id="ob-slides">

      <!-- شريحة 1 -->
      <div class="ob-slide">
        <span class="ob-emoji">🖨️</span>
        <h2 class="ob-title">خدمات الشاطر الطلابية</h2>
        <p class="ob-desc">اطبع مستنداتك بسهولة تامة — ارفع الملفات واختر إعدادات الطباعة وحدد موقعك، وسنوصّل لك في أسرع وقت!</p>
      </div>

      <!-- شريحة 2 -->
      <div class="ob-slide">
        <span class="ob-emoji">📦</span>
        <h2 class="ob-title">تتبع طلبك لحظة بلحظة</h2>
        <p class="ob-desc">ستصلك إشعارات فورية على تيليجرام عند كل تغيير في حالة طلبك:<br><br>📥 مستلم ← 🖨️ طباعة ← 🛵 توصيل ← ✅ تسليم</p>
      </div>

      <!-- شريحة 3 -->
      <div class="ob-slide">
        <span class="ob-emoji">💎</span>
        <h2 class="ob-title">اكسب نقاط ولاء مع كل طلب!</h2>
        <p class="ob-desc">كل 1,000 د.ع تنفقها = 10 نقاط ولاء.<br>استبدل نقاطك بخصومات حصرية. وعند الوصول للمستوى الذهبي تحصل على خصم 5% دائم! 🥇</p>
      </div>

    </div>

    <!-- Dots -->
    <div class="ob-dots">
      <div class="ob-dot active" id="od0"></div>
      <div class="ob-dot"        id="od1"></div>
      <div class="ob-dot"        id="od2"></div>
    </div>

    <button class="ob-next" id="ob-next-btn" onclick="obNext()">التالي ←</button>
  </div>
</div>

<!-- ══════════════════════════════════════
     WELCOME MODAL
══════════════════════════════════════ -->
<div id="wmodal">
  <div class="mbox">
    <img src="Logo.jpg" alt="خدمات الشاطر" class="app-logo"
         onerror="this.outerHTML=`<div class='app-logo' style='display:flex;align-items:center;justify-content:center;font-size:2.5rem;'>🖨️</div>`">
    <h2 style="color:var(--navy);margin:0 0 8px;font-weight:800;">خدمات الشاطر الطلابية</h2>
    <p style="color:var(--text-muted);margin:0 0 15px;font-weight:500;">ارفع مستنداتك وسنطبعها ونوصلها إليك</p>
    <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:14px;padding:12px;margin-bottom:15px;">
      <p id="fo-gift" style="font-size:.9rem;color:var(--green);font-weight:800;margin:0 0 5px;display:none;">🎁 توصيل مجاني لأول طلب!</p>
      <p style="font-size:.88rem;color:var(--green);font-weight:700;margin:0;">🎁 توصيل مجاني للطلبات +10,000 د.ع</p>
