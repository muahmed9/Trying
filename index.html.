    const {data} = await sb.from('users').select('*').eq('id', userId).maybeSingle();
    if (data) { uDoc=data; refreshPtsUI(); }
    const {data:ords} = await sb.from('orders').select('id,loyalty_points_earned,pts_used,created_at').eq('user_id',userId).order('created_at',{ascending:false}).limit(20);
    let h='';
    (ords||[]).forEach(o=>{
      const d=new Date(o.created_at).toLocaleDateString('ar-IQ');
      if(o.loyalty_points_earned>0) h+=`<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--border);"><div><b style="font-size:.95rem;color:var(--navy);">طلب #${o.id}</b><div style="font-size:.8rem;color:var(--text-muted);margin-top:3px;">${d}</div></div><span style="background:#dcfce7;color:#166534;font-weight:800;padding:5px 12px;border-radius:10px;font-size:.9rem;">+${o.loyalty_points_earned} نقطة</span></div>`;
      if(o.pts_used>0) h+=`<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--border);"><div><b style="font-size:.95rem;color:var(--navy);">استبدال مكافأة</b><div style="font-size:.8rem;color:var(--text-muted);margin-top:3px;">طلب #${o.id} • ${d}</div></div><span style="background:#fee2e2;color:#991b1b;font-weight:800;padding:5px 12px;border-radius:10px;font-size:.9rem;">−${o.pts_used} نقطة</span></div>`;
    });
    document.getElementById('ptshist').innerHTML = h||'<p style="color:#94a3b8;font-size:.9rem;text-align:center;padding:10px;">لا يوجد سجل بعد. أكمل أول طلب لتبدأ بجمع النقاط!</p>';
  } catch{}
}

// ═══════════════════════════════════════
//  HELPERS
// ═══════════════════════════════════════
function showErr(m){const e=document.getElementById('errbox');e.innerText=m;e.style.display='block';}
function hideErr(){document.getElementById('errbox').style.display='none';}
function showToast(m){const t=document.getElementById('toast');t.innerText=m;t.style.display='block';clearTimeout(t._t);t._t=setTimeout(()=>t.style.display='none',4000);}

// ═══════════════════════════════════════
//  START
// ═══════════════════════════════════════
init();
</script>
</body>
</html>

