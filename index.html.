  } else pc.style.display = 'none';

  const tot = Math.max(0, pp-td-pd+df);
  const pe  = Math.floor(tot/1000)*10;
  const dtxt = isFO ? '<b style="color:#4eff4e;">مجاني 🎁</b>' : df===0 ? '<b style="color:#4eff4e;">مجاني ✨</b>' : df.toLocaleString()+' د.ع';

  document.getElementById('invdet').innerHTML = `
    <div class="il"><span>إجمالي الصفحات:</span><span style="font-weight:bold;">${dp}</span></div>
    <div class="il"><span>الصور:</span><span style="font-weight:bold;">${im}</span></div>
    <div class="il" style="border-top:1px solid rgba(255,255,255,0.2);padding-top:10px;margin-top:5px;"><span>سعر الطباعة الأساسي:</span><span style="font-weight:bold;">${pp.toLocaleString()} د.ع</span></div>
    ${td>0?`<div class="il"><span>🥇 خصم العضوية الذهبية (5%):</span><span style="color:#4eff4e;font-weight:bold;">−${td.toLocaleString()} د.ع</span></div>`:''}
    ${pd>0&&useP?`<div class="il"><span>💎 خصم استبدال النقاط:</span><span style="color:#4eff4e;font-weight:bold;">−${pd.toLocaleString()} د.ع</span></div>`:''}
    <div class="il"><span>أجور التوصيل:</span><span style="font-weight:bold;">${dtxt}</span></div>
    <div class="il" style="background:rgba(0,0,0,0.2);padding:10px;border-radius:10px;margin-top:10px;"><span>💎 نقاط ستكسبها (بعد الاستلام):</span><span style="color:var(--gold);font-weight:bold;font-size:1.1rem;">+${pe}</span></div>`;
  document.getElementById('totlbl').innerText = `المجموع النهائي: ${tot.toLocaleString()} د.ع`;
  window._ord = {pp,df,td,pd,tot,pe,isFO};
}

