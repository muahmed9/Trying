<script>
// ═══════════════════════════════════════
//  CONFIG
// ═══════════════════════════════════════
const SB_URL = 'https://zrumnqtgdscrwgcguseq.supabase.co';
const SB_KEY = 'sb_publishable_xEqE6S21QUMCkDxSMvTskg_9g3pi-vZ';
const BOT    = '8507186698:AAHXCtsLn8j88A2QgiXSmNFbnEfpn1nCYew';
const ADMIN  = '7618746133';

const sb  = window.supabase.createClient(SB_URL, SB_KEY);
const tg  = window.Telegram?.WebApp; tg?.ready();
const tgU = tg?.initDataUnsafe?.user;
const userId = tgU?.id ? String(tgU.id) : 'guest_' + Date.now();

let files=[], color='c', side='1', locUrl='', pendingR=null;
let uDoc = {loyalty_points:0,first_order_done:false,total_orders:0,total_spent:0};

// ═══════════════════════════════════════
//  DARK MODE
// ═══════════════════════════════════════
function applyTheme(dark) {
  document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
  document.getElementById('dm-icon').innerText  = dark ? '☀️' : '🌙';
  document.getElementById('dm-label').innerText = dark ? 'نهاري' : 'ليلي';
}
function toggleDark() {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  localStorage.setItem('shater-dark', !isDark);
  applyTheme(!isDark);
}
// Load saved preference
applyTheme(localStorage.getItem('shater-dark') === 'true');

// ═══════════════════════════════════════
//  ONBOARDING
// ═══════════════════════════════════════
let obIdx = 0;
const obTotal = 3;

function obNext() {
  obIdx++;
  if (obIdx >= obTotal) { finishOnboarding(); return; }
  document.getElementById('ob-slides').style.transform = `translateX(${obIdx * 100}%)`;
  document.querySelectorAll('.ob-dot').forEach((d,i) => d.classList.toggle('active', i === obIdx));
  document.getElementById('ob-next-btn').innerText = obIdx === obTotal-1 ? 'ابدأ الآن! 🚀' : 'التالي ←';
}

function finishOnboarding() {
  document.getElementById('onboarding').style.display = 'none';
  localStorage.setItem('shater-ob', '1');
  if (!uDoc.first_order_done) document.getElementById('wmodal').style.display = 'flex';
}

// Show onboarding only once
if (localStorage.getItem('shater-ob') === '1') {
  document.getElementById('onboarding').style.display = 'none';
}

// ═══════════════════════════════════════
//  INIT
// ═══════════════════════════════════════
async function init() {
  try {
    const {data} = await sb.from('users').select('*').eq('id', userId).maybeSingle();
    if (data) { uDoc = data; }
    else {
      uDoc = {id:userId, name:tgU?.first_name||'', username:tgU?.username||'',
              loyalty_points:0, total_orders:0, total_spent:0, first_order_done:false};
      await sb.from('users').insert(uDoc);
    }
  } catch(e) {}
  if (!uDoc.first_order_done) document.getElementById('fo-gift').style.display = 'block';
  refreshPtsUI();
  startRT();
}

// ═══════════════════════════════════════
//  REAL-TIME
// ═══════════════════════════════════════
function startRT() {
  try {
    sb.channel('public-orders')
      .on('postgres_changes', {event:'UPDATE', schema:'public', table:'orders'},
        p => {
          if (p.new.user_id !== userId && p.new.telegram_id !== userId) return;
          const m = {received:'📥 تم الاستلام',printing:'🖨️ قيد الطباعة',delivering:'🛵 جاري التوصيل',delivered:'✅ تم التسليم',cancelled:'❌ ملغى'};
          showToast('🔔 تحديث طلبك: ' + (m[p.new.status] || p.new.status));
          if (document.getElementById('tab-orders').classList.contains('active')) loadOrders();
          const detTitle = document.getElementById('det-title').innerText;
          if (document.getElementById('det-ov').classList.contains('open') && detTitle.includes(p.new.id)) showDet(p.new.id);
          if (p.new.status === 'delivered') init();
        })
      .subscribe();
  } catch(e) {}
}

// ═══════════════════════════════════════
//  TABS
// ═══════════════════════════════════════
function goTab(t) {
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nbtn').forEach(x=>x.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  document.getElementById('nav-'+t).classList.add('active');
  if (t==='orders') loadOrders();
  if (t==='points') loadPtsTab();
}

// ═══════════════════════════════════════
//  FILE INPUT — تأكيد بصري محسّن
// ═══════════════════════════════════════
const FILE_ICONS = {
  pdf:'📕', doc:'📘', docx:'📘', xls:'📗', xlsx:'📗',
  ppt:'📙', pptx:'📙', jpg:'🖼️', jpeg:'🖼️', png:'🖼️', webp:'🖼️'
};
const FILE_COLORS = {
  pdf:'fi-pdf', doc:'fi-word', docx:'fi-word', xls:'fi-xl', xlsx:'fi-xl',
  ppt:'fi-ppt', pptx:'fi-ppt', jpg:'fi-img', jpeg:'fi-img', png:'fi-img', webp:'fi-img'
};

document.getElementById('fileinp').onchange = async e => {
  const ok=['.pdf','.docx','.doc','.xlsx','.xls','.pptx','.ppt','.jpg','.jpeg','.png','.webp'];
  for (const f of e.target.files) {
    const nm = f.name.toLowerCase(), ext = nm.substring(nm.lastIndexOf('.'));
    if (!ok.includes(ext) && !f.type.startsWith('image/')) continue;
    const obj = {file:f, name:f.name, p:1, c:1, isImg:f.type.startsWith('image/'), type:'ملف'};
    try {
      const buf = await f.arrayBuffer();
      if (nm.endsWith('.pdf')) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
        obj.p = (await pdfjsLib.getDocument({data:buf}).promise).numPages;
        obj.type = 'PDF'; obj.isImg = false;
      } else if (nm.endsWith('.docx') || nm.endsWith('.doc')) {
        try {
          const z = await JSZip.loadAsync(buf), xf = z.file('docProps/app.xml');
          if (xf) { const m = (await xf.async('string')).match(/<Pages>(\d+)<\/Pages>/); if(m) obj.p = +m[1]; }
        } catch {
          const r = await mammoth.extractRawText({arrayBuffer:buf});
          obj.p = Math.max(1, Math.ceil(r.value.trim().split(/\s+/).length / 300));
        }
        obj.type = 'Word'; obj.isImg = false;
      } else if (nm.endsWith('.pptx') || nm.endsWith('.ppt')) {
        const z = await JSZip.loadAsync(buf), xf = z.file('docProps/app.xml');
        if (xf) { const m = (await xf.async('string')).match(/<Slides>(\d+)<\/Slides>/); if(m) obj.p = +m[1]; }
        obj.type = 'PowerPoint'; obj.isImg = false;
      } else if (nm.endsWith('.xlsx') || nm.endsWith('.xls')) {
        const wb = XLSX.read(buf,{type:'array'}); let tot = 0;
        wb.SheetNames.forEach(s => { const sh=wb.Sheets[s], r=XLSX.utils.decode_range(sh['!ref']||'A1:A1'); tot+=Math.ceil((r.e.r-r.s.r+1)/45)*Math.ceil((r.e.c-r.s.c+1)/8); });
        obj.p = Math.max(1,tot); obj.type = 'Excel'; obj.isImg = false;
      } else if (obj.isImg) obj.type = 'صورة';
    } catch { obj.p = 1; }
    files.push(obj);
  }
  calcUI(); e.target.value = '';
};

function getFileExt(name) { return name.toLowerCase().split('.').pop() || 'other'; }
function getFileSize(f) {
  const b = f.file.size;
  if (b < 1024) return b + ' B';
  if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
  return (b/1048576).toFixed(1) + ' MB';
}

// ═══════════════════════════════════════
//  PRINT CONFIG
// ═══════════════════════════════════════
function setC(v) { color=v; document.getElementById('cbtn').className=v==='c'?'obtn on':'obtn off'; document.getElementById('nbtn').className=v==='n'?'obtn on':'obtn off'; calcUI(); }
function setS(v) { side=v; document.getElementById('s1btn').className=v==='1'?'obtn on':'obtn off'; document.getElementById('s2btn').className=v==='2'?'obtn on':'obtn off'; calcUI(); }

// ═══════════════════════════════════════
//  LOCATION
// ═══════════════════════════════════════
function getLoc() {
  navigator.geolocation.getCurrentPosition(
    p => { locUrl=`https://www.google.com/maps?q=${p.coords.latitude},${p.coords.longitude}`; const b=document.getElementById('locbtn'); b.innerText='✅ تم حفظ الموقع الجغرافي بنجاح'; b.style.background='var(--green)'; hideErr(); },
    () => showErr('❌ يرجى تفعيل GPS والسماح بالوصول للموقع')
  );
}

// ═══════════════════════════════════════
//  PRICING
// ═══════════════════════════════════════
function calcPrice(sh, im) {
  const t=sh+im; if(!t) return 0; if(t<=5) return 1000;
  if(color==='c') { if(t<=25) return t*150; if(t<=40) return t*130; if(t<=70) return t*120; return t*100; }
  return t*(side==='1'?90:75);
}

// ═══════════════════════════════════════
//  UI UPDATE
// ═══════════════════════════════════════
function calcUI() {
  let sh=0, im=0, dp=0, hasD=false, hasI=false;
  const fl = document.getElementById('flist');
  fl.innerHTML = '';

  if (files.length > 0) {
    // Header
    fl.innerHTML = `<div class="card" style="margin-bottom:0;">
      <p style="margin:0 0 12px;color:var(--navy);font-weight:800;font-size:.95rem;">📂 الملفات المرفقة (${files.length})</p>`;

    files.forEach((f,i) => {
      if(f.isImg) { hasI=true; im+=f.c; }
      else { hasD=true; dp+=f.p*f.c; const u=f.type==='PowerPoint'?Math.ceil(f.p/2):f.p; sh+=(side==='2'?Math.ceil(u/2):u)*f.c; }
      const ext   = getFileExt(f.name);
      const icon  = FILE_ICONS[ext]  || '📄';
      const clr   = FILE_COLORS[ext] || 'fi-other';
      const size  = getFileSize(f);
      fl.innerHTML += `
        <div class="file-card">
          <div class="file-icon-box ${clr}">${icon}</div>
          <div class="file-info">
            <div class="file-name" title="${f.name}">${f.name}</div>
            <div class="file-meta">${size} &nbsp;•&nbsp; ${f.p} صفحة</div>
            <span class="file-badge">${f.type}</span>
          </div>
          <div class="file-controls">
            <button class="bcnt" onclick="adjC(${i},-1)">−</button>
            <span class="file-qty">${f.c}</span>
            <button class="bcnt" onclick="adjC(${i},1)">+</button>
            <button class="del-btn" onclick="rmF(${i})">حذف</button>
          </div>
        </div>`;
    });
    fl.innerHTML += '</div>';
  }

  document.getElementById('sidebox').style.display = hasD ? 'block' : 'none';
  document.getElementById('inote').style.display   = hasI ? 'block' : 'none';
  document.getElementById('flist').style.display   = files.length ? 'block' : 'none';
  document.getElementById('opts').style.display    = files.length ? 'block' : 'none';

  const pp = calcPrice(sh, im);
  const isFO = !uDoc.first_order_done;
  const df   = files.length===0 ? 0 : (pp>=10000||isFO ? 0 : 1000);
  const isG  = (uDoc.loyalty_points||0) >= 500;
  const td   = isG ? Math.round(pp*.05) : 0;
  const useP = document.getElementById('ptstog')?.checked && pendingR;
  const pd   = useP ? pendingR.disc : 0;

  const pc = document.getElementById('ptscard');
  if (pendingR && files.length) {
    pc.style.display = 'block';
